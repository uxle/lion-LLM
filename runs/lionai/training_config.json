{
  "output_dir": "runs/lionai",
  "dataset_path": "data/train.jsonl",
  "resume_from": null,
  "max_seq_length": 64,
  "min_seq_length": 8,
  "train_split": 0.85,
  "pack_sequences": true,
  "learning_rate": 0.0005,
  "weight_decay": 0.01,
  "beta1": 0.9,
  "beta2": 0.95,
  "eps": 1e-08,
  "grad_clip": 1.0,
  "lr_decay_end": 0.1,
  "layer_lr_decay": 1.0,
  "warmup_steps": 128,
  "max_steps": 1280,
  "lr_schedule": "cosine",
  "batch_size": 4,
  "gradient_accumulation": 1,
  "auto_batch_size": true,
  "gradient_checkpointing": false,
  "use_torch_compile": false,
  "dtype": "auto",
  "eval_interval": 128,
  "eval_steps": 10,
  "save_interval": 256,
  "keep_checkpoints": 2,
  "patience": 5,
  "patience_delta": 0.005,
  "log_interval": 64
}